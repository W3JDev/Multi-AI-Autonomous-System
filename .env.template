# Environment Variables Template
# Copy this file to .env.local in each app directory and fill in the values

# ==============================================================================
# DATABASE
# ==============================================================================
# PostgreSQL database URL (Supabase or custom)
DATABASE_URL="postgresql://user:password@host:5432/database"

# Direct database URL (for migrations)
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/database"

# ==============================================================================
# AI SERVICES
# ==============================================================================
# Google Gemini API Key
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# DeepSeek API Key (fallback)
# Get from: https://platform.deepseek.com/
DEEPSEEK_API_KEY="your_deepseek_api_key_here"

# ==============================================================================
# SUPABASE
# ==============================================================================
# Supabase project URL
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL="https://xxxxxxxxxxxxx.supabase.co"

# Supabase anonymous key
# Get from: Supabase Dashboard → Settings → API
SUPABASE_ANON_KEY="your_supabase_anon_key_here"

# Supabase service role key (for admin operations)
# Get from: Supabase Dashboard → Settings → API
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"

# ==============================================================================
# AUTHENTICATION
# ==============================================================================
# Next.js auth URL (change for each app)
NEXTAUTH_URL="http://localhost:3000"
# Production: https://dashboard.w3jdev.com

# Next.js auth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="generate_random_secret_with_openssl_rand_base64_32"

# OAuth Providers (optional)
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"

# ==============================================================================
# MONITORING
# ==============================================================================
# Sentry DSN for error tracking
# Get from: https://sentry.io → Project Settings → Client Keys (DSN)
SENTRY_DSN="https://xxxxxxxxxxxxx@sentry.io/xxxxxxx"

# Sentry Auth Token (for releases and source maps)
SENTRY_AUTH_TOKEN="your_sentry_auth_token"

# Sentry Organization
SENTRY_ORG="your_organization_name"

# Sentry Project
SENTRY_PROJECT="your_project_name"

# ==============================================================================
# API GATEWAY
# ==============================================================================
# API Gateway URL
API_GATEWAY_URL="http://localhost:3000"
# Production: https://api.w3jdev.com

# WebSocket URL
WEBSOCKET_URL="ws://localhost:3001"
# Production: wss://api.w3jdev.com:3001

# ==============================================================================
# NOTIFICATIONS
# ==============================================================================
# Slack Webhook for alerts (optional)
# Get from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK="https://hooks.slack.com/services/YOUR/WEBHOOK/URL"

# Email service (optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"

# ==============================================================================
# STORAGE
# ==============================================================================
# Cloudflare R2 (optional, for static assets)
R2_ACCOUNT_ID="your_account_id"
R2_ACCESS_KEY_ID="your_access_key_id"
R2_SECRET_ACCESS_KEY="your_secret_access_key"
R2_BUCKET_NAME="your_bucket_name"

# ==============================================================================
# DEVELOPMENT
# ==============================================================================
# Node environment
NODE_ENV="development"
# Production: "production"

# Log level
LOG_LEVEL="debug"
# Production: "info"

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================
# Enable/disable features
ENABLE_AUTO_RECOVERY="true"
ENABLE_SENTRY="true"
ENABLE_ANALYTICS="true"

# ==============================================================================
# RATE LIMITING
# ==============================================================================
# Rate limit settings (requests per minute)
RATE_LIMIT_MAX="60"
RATE_LIMIT_WINDOW="60000"

# ==============================================================================
# DEPLOYMENT
# ==============================================================================
# Vercel (for CI/CD)
VERCEL_TOKEN="your_vercel_token"
VERCEL_ORG_ID="your_org_id"
VERCEL_PROJECT_ID="your_project_id"

# Railway (for API Gateway)
RAILWAY_TOKEN="your_railway_token"

# ==============================================================================
# APP-SPECIFIC SETTINGS
# ==============================================================================
# PUNCH-CLOCK
NEXT_PUBLIC_APP_NAME="PUNCH-CLOCK"
NEXT_PUBLIC_APP_URL="https://punch-clock.w3jdev.com"

# AI-Artisan
NEXT_PUBLIC_APP_NAME="AI-Artisan"
NEXT_PUBLIC_APP_URL="https://ai-artisan.w3jdev.com"

# FlairAi
NEXT_PUBLIC_APP_NAME="FlairAi"
NEXT_PUBLIC_APP_URL="https://flair-ai.w3jdev.com"

# Serene-AI
NEXT_PUBLIC_APP_NAME="Serene-AI"
NEXT_PUBLIC_APP_URL="https://serene-ai.w3jdev.com"

# Restaurant AI (WaiterAi + GuestAi)
NEXT_PUBLIC_APP_NAME="Restaurant AI"
NEXT_PUBLIC_APP_URL="https://restaurant-ai.w3jdev.com"

# Unified Dashboard
NEXT_PUBLIC_APP_NAME="W3JDev Dashboard"
NEXT_PUBLIC_APP_URL="https://dashboard.w3jdev.com"

# ==============================================================================
# NOTES
# ==============================================================================
# - Never commit this file with actual values
# - Add .env.local to .gitignore
# - Use different values for development and production
# - Rotate secrets regularly
# - Use environment-specific files: .env.development, .env.production
